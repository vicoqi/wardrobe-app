{
  "expo": {
    "name": "wardrobe-app",
    "slug": "wardrobe-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFE5EC"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wardrobe.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "需要获取您的位置以提供当地天气信息，帮助您选择合适的穿搭"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFE5EC"
      },
      "package": "com.wardrobe.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "需要访问相册以选择衣服图片",
          "cameraPermission": "需要访问相机以拍摄衣服照片"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "需要获取您的位置以提供当地天气信息，帮助您选择合适的穿搭",
          "locationWhenInUsePermission": "需要获取您的位置以提供当地天气信息"
        }
      ],
      "expo-sqlite",
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "8915054f-d1de-476f-ac80-0201c0e99468"
      }
    },
    "owner": "chipwat"
  }
}
